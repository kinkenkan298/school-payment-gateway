meta {
  name: [GW] Create Settlement
  type: http
  seq: 1
}

post {
  url: {{base_url_gateway}}/api/v1/settlements
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "schoolId": "{{school_id}}",
    "notes": "Settlement manual bulan Maret 2026"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("settlement_id", res.body.data._id);
    bru.setEnvVar("settlement_batch_id", res.body.data.batchId);
  }
}
