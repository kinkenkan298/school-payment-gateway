meta {
  name: [GW] Get All Fraud Alerts
  type: http
  seq: 1
}

get {
  url: {{base_url_gateway}}/api/v1/fraud-alerts?page=1&limit=10
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

script:post-response {
  if (res.status === 200 && res.body.data.length > 0) {
    bru.setEnvVar("fraud_alert_id", res.body.data[0]._id);
  }
}
