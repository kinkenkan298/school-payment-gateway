meta {
  name: [GW] Refresh Token
  type: http
  seq: 3
}

post {
  url: {{base_url_gateway}}/api/v1/auth/refresh-token
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refresh_token}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("access_token", res.body.data.accessToken);
  }
}
