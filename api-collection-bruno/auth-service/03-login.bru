meta {
  name: Login
  type: http
  seq: 3
}

post {
  url: {{base_url_auth}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "budi@gmail.com",
    "password": "Password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("access_token", res.body.data.accessToken);
    bru.setEnvVar("refresh_token", res.body.data.refreshToken);
  }
}
