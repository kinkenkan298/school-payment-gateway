meta {
  name: [Webhook] Xendit - Payment Expired
  type: http
  seq: 11
}

post {
  url: {{base_url_payment}}/payments/webhook/xendit
  body: json
  auth: none
}

headers {
  x-callback-token: skip_in_dev
}

body:json {
  {
    "id": "XENDIT_INV_002",
    "external_id": "{{external_id}}",
    "status": "EXPIRED",
    "amount": 255000,
    "currency": "IDR"
  }
}
